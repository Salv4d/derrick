# Ignore the generated binary (we will compile it as 'derrick')
/derrick
bin/
*.test
*.out

# Nix build output symlink
/result
/result-*

# Ignore environment variables generated by our auto-fix tests
.env

# OS & Editor files
.DS_Store
.vscode/
.idea/
*.swp
*.swo


# Derrick auto-generated files
.derrick/
.derrick-code/
node_modules/
tmp

# AI coding tool session files (Aider, Claude, etc.)
.aider*
.claude/

# Research repositories cloned for architecture analysis
.derrick-research/

# Ephemeral temp sandboxes created by `derrick run`
.derrick-tmp-*/

# Claude Code task and planning artifacts
.tasks/
CODEBASE_REPORT.md
TEST_PLAN.md
run-command-improvements.md
GEMINI_REVIEW_PROMPT.md
WALKTHROUGH.md
